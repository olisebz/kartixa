# ============================================================================
# Kartixa Backend Configuration
# Copy to .env and adjust values
# ============================================================================

# MariaDB Connection
# Use "db" when running via docker compose, "localhost" for local dev
DATABASE_HOST=db
DATABASE_PORT=3306
DATABASE_USER=kartixa
DATABASE_PASSWORD=kartixa_dev
DATABASE_NAME=kartixa
DATABASE_SSL=false

# NextAuth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# OTP / session token signing secret
# Generate with: openssl rand -base64 32
# If not set, falls back to AUTH_SECRET — set explicitly in production
AUTH_CHALLENGE_SECRET=

# CORS (comma-separated origins)
# IMPORTANT: Set to your production domain in production, e.g. https://kartixa.example.com
CORS_ORIGINS=http://localhost:3000

# Environment
NODE_ENV=development

# Rate Limiting (requests per window)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Email / SMTP (optional — set MAIL_ENABLED=true to send real emails)
MAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Kartixa <no-reply@kartixa.local>
